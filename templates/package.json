{
  "name": "templates",
  "version": "6.6.3",
  "private": "true",
  "license": "MIT",
  "vsversion": "18.6.0",
  "scripts": {
    "precommit": "lint-staged",
    "upgrade-schema": "node ./scripts/yamlSolver upgrade-schema",
    "clean": "rimraf ./build",
    "build": "npm run generate:vsc && npm run generate:vs && npm run distribute && npm run build:release",
    "build:vsc": "npm run generate:vsc && npm run distribute",
    "build:vs": "npm run generate:vs && npm run distribute",
    "build:release": "node ./scripts/generateRelease.js",
    "generate:vsc": "node ./scripts/generateVSCZip.js && tsx ./scripts/generate-metadata.ts",
    "generate:vs": "node ./scripts/generateVSZip.js",
    "distribute": "copyfiles -u 1 \"build/**/*\" ../packages/fx-core/templates/ && copyfiles -u 3 \"src/ui/resource/**/*\" ../packages/fx-core/resource/templates/ && shx cp -r configs/ ../packages/fx-core/templates/",
    "version": "bash ../.github/scripts/pkg-version.sh template-sync && bash ../.github/scripts/pkg-version.sh core-template",
    "postversion": "npm run build"
  },
  "templatesDependOnSDK": [
    "vsc/js/command-and-response",
    "vsc/js/dashboard-tab",
    "vsc/js/default-bot-message-extension",
    "vsc/js/message-extension",
    "vsc/js/non-sso-tab-default-bot",
    "vsc/js/notification-http-timer-trigger",
    "vsc/js/notification-http-trigger",
    "vsc/js/notification-express",
    "vsc/js/notification-timer-trigger",
    "vsc/js/workflow",
    "vsc/ts/command-and-response",
    "vsc/ts/dashboard-tab",
    "vsc/ts/default-bot-message-extension",
    "vsc/ts/message-extension",
    "vsc/ts/non-sso-tab-default-bot",
    "vsc/ts/notification-http-timer-trigger",
    "vsc/ts/notification-http-trigger",
    "vsc/ts/notification-express",
    "vsc/ts/notification-timer-trigger",
    "vsc/ts/workflow"
  ],
  "devDependencies": {
    "adm-zip": "^0.5.10",
    "copyfiles": "^2.4.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-headers": "^1.3.4",
    "eslint-plugin-import-x": "^4.16.0",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-office-addins": "3.0.2",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^16.2.0",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.0.0",
    "mustache": "^4.2.0",
    "prettier": "^2.4.1",
    "rimraf": "^6.0.1",
    "semver": "^7.3.5",
    "shx": "^0.3.4",
    "tslint": "^6.1.3",
    "tsx": "^4.20.6",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.0"
  },
  "lint-staged": {
    "*.{js,jsx,css,ts,tsx}": [
      "npx eslint --cache --fix --quiet"
    ]
  }
}
