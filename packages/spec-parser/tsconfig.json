{
  "compileOnSave": false,
  "compilerOptions": {
    "module": "ES2015",
    "outDir": "dist",
    "declarationDir": "./dist",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "dom"
    ],
    "declaration": true,
    "sourceMap": true,
    "importHelpers": true,
    "strict": true,
    "alwaysStrict": true,
    "noUnusedLocals": false, // TODO: temporarily disabled
    "noUnusedParameters": false, // TODO: temporarily disabled
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "exclude": ["dist/**/*", "config/*"]
}
