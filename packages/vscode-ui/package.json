{
  "name": "@microsoft/vscode-ui",
  "version": "1.0.14",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "license": "MIT",
  "publisher": "TeamsDevApp",
  "scripts": {
    "lint:staged": "lint-staged",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:unit": "nyc mocha \"tests/**/*.test.ts\" ",
    "clean": "rm -rf build",
    "build": "rimraf build && npx tsc -p ./",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build",
    "package": "rimraf build && webpack --mode production --config ./webpack.config.js",
    "check-sensitive": "npx eslint --cache --ignore-pattern 'package.json' --ignore-pattern 'package-lock.json'",
    "precommit": "npm run check-sensitive && lint-staged",
    "installAll": "npm run install:tabs"
  },
  "dependencies": {
    "@microsoft/teamsfx-api": "workspace:*",
    "async-mutex": "^0.3.1",
    "jsonschema": "1.4.0",
    "lodash": "^4.17.21",
    "tmp": "^0.2.5"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@types/chai": "^4.2.14",
    "@types/chai-as-promised": "^7.1.3",
    "@types/chai-spies": "^1.0.3",
    "@types/lodash": "^4.14.181",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.0",
    "@types/sinon": "^17.0.0",
    "@types/tmp": "^0.2.0",
    "@types/vscode": "^1.66.0",
    "chai": "^4.2.0",
    "chai-as-promised": "^7.1.1",
    "chai-spies": "^1.0.0",
    "copy-webpack-plugin": "^6.4.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-headers": "^1.3.4",
    "eslint-plugin-import-x": "^4.16.0",
    "eslint-plugin-no-secrets": "^1.1.2",
    "eslint-plugin-prettier": "^5.5.0",
    "globals": "^16.2.0",
    "lint-staged": "^10.5.4",
    "mocha": "^11.0.0",
    "mocked-env": "^1.3.5",
    "nyc": "^17.1.0",
    "prettier": "^2.4.1",
    "sinon": "^19.0.0",
    "source-map-support": "^0.5.19",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "ts-sinon": "2.0.2",
    "tslib": "^2.3.1",
    "typemoq": "1.3.1",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.56.0"
  },
  "files": [
    "build/**/*"
  ],
  "gitHead": "7d60c0765c0ea8c023a26c10d1c93001c597afbb",
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.{js,jsx,css,ts,tsx}": [
      "npx eslint --cache --fix --quiet"
    ],
    "*.json": [
      "npx prettier --cache --write --ignore-unknown"
    ]
  }
}
