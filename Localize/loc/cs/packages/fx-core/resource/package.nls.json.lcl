      <Item ItemId=";error.dep.CopilotDisabledError" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Microsoft 365 account administrator hasn't enabled Copilot access for this account. Contact your Teams administrator to resolve this issue by enrolling in Microsoft 365 Copilot Early Access program. Visit: https://aka.ms/PluginsEarlyAccess]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Microsoft 365 správce účtu nepovolil pro tento účet přístup ke službě Copilot. Pokud chcete tento problém vyřešit, obraťte se na správce Teams tím, že se zaregistrujete do programu Microsoft 365 Copilot Early Access. Navštivte: https://aka.ms/PluginsEarlyAccess]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";error.dep.FindProcessError" ItemType="0" PsrId="306" Leaf="true">
