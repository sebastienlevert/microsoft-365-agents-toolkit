      <Item ItemId=";action.devTool.nodeInstaller.Confirm" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[NodeJS is required to launch test tool, which is not installed in system environment or user folder. Do you want to install the latest LTS version (%s) of NodeJS in your user folder? (Note: the installation will not change your system environment globally.)]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Spuštění testovacího nástroje, který není nainstalovaný v systémovém prostředí ani ve složce uživatele, vyžaduje NodeJS. Chcete do složky uživatele nainstalovat nejnovější verzi LTS (%s) prostředí NodeJS? (Poznámka: Instalace nezmění systémové prostředí v globálním měřítku.)]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
