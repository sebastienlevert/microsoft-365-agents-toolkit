        <Str Cat="Text">
          <Val><![CDATA[Build a declarative agent to customize Microsoft 365 Copilot with specific instructions, actions, and knowledge. Follow this guide to get started.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Consente di creare un agente dichiarativo per personalizzare Microsoft 365 Copilot con istruzioni, azioni e conoscenze specifiche. Per iniziare, segui questa guida.]]></Val>
          </Tgt>
        </Str>
