      <Item ItemId=";teamstoolkit.walkthroughs.buildIntelligentApps.copilotPlugin.description" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Transform your app into a plugin to enhance Copilot's skills and boost user productivity in daily tasks and workflows. Explore [Copilot Extensibility]5D;(https://learn.microsoft.com/en-us/microsoft-365-copilot/extensibility/)]A;[Check Copilot Access]5D;(command:fx-extension.checkCopilotAccess?%5B%22WalkThrough%22%5D)]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Trasforma l'app in un plug-in per migliorare le competenze di Copilot e aumentare la produttività degli utenti nelle attività e nei flussi di lavoro giornalieri. Esplora [Copilot Extensibility]5D;(https://learn.microsoft.com/en-us/microsoft-365-copilot/extensibility/)]A;[Check Copilot Access]5D;(command:fx-extension.checkCopilotAccess?%5B%22WalkThrough%22%5D)]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";teamstoolkit.walkthroughs.buildIntelligentApps.copilotPlugin.title" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[API Plugin]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Plug-in API]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
      <Item ItemId=";teamstoolkit.walkthroughs.buildIntelligentApps.customCopilot.description" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[Build your intelligent, natural language-driven experiences in Teams, leveraging its vast user base for collaboration. ]A;Microsoft 365 Agents Toolkit integrates with Azure OpenAI and Microsoft Teams SDK to streamline copilot development and offer unique Teams-based capabilities. ]A;Explore [Microsoft Teams SDK]5D;(https://aka.ms/teams-ai-library-v2) and [Azure OpenAI Service]5D;(https://learn.microsoft.com/en-us/azure/ai-services/openai/overview)]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Crea esperienze intelligenti e basate sul linguaggio naturale in Teams, sfruttando la vasta base di utenti per la collaborazione. ]A;Toolkit agenti di Microsoft 365 si integra con Azure OpenAI e Microsoft Teams SDK per semplificare lo sviluppo di Copilot e offrire funzionalità esclusive basate su Teams. ]A;Esplora [Microsoft Teams SDK]5D;(https://aka.ms/teams-ai-library-v2) e il [Servizio Azure OpenAI]5D;(https://learn.microsoft.com/it-it/azure/ai-services/openai/overview)]]></Val>
          </Tgt>
          <Prev Cat="Text">
            <Val><![CDATA[Build your intelligent, natural language-driven experiences in Teams, leveraging its vast user base for collaboration. ]A;Microsoft 365 Agents Toolkit integrates with Azure OpenAI and Teams AI Library to streamline copilot development and offer unique Teams-based capabilities. ]A;Explore [Teams AI Library]5D;(https://learn.microsoft.com/en-us/microsoftteams/platform/bots/how-to/teams%20conversational%20ai/teams-conversation-ai-overview) and [Azure OpenAI Service]5D;(https://learn.microsoft.com/en-us/azure/ai-services/openai/overview)]]></Val>
          </Prev>
        </Str>
        <Disp Icon="Str" />
      </Item>
