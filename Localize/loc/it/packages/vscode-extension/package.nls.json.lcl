      <Item ItemId=";_teamstoolkit.handlers.installAdaptiveCardExt" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[product name, no need to translate 'Adaptive Card Previewer'.]]></Val>
