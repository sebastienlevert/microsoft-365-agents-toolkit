      <Item ItemId=";teamstoolkit.walkthroughs.buildIntelligentApps.intelligentAppsPreview.description" ItemType="0" PsrId="306" Leaf="true">
        <Str Cat="Text">
          <Val><![CDATA[To preview your declarative agent, [Provision]5D;(command:fx-extension.provision) it for Microsoft 365 Copilot and Launch Microsoft 365 Copilot for [Preview]5D;(command:fx-extension.localdebug).]A;[Provision]5D;(command:fx-extension.provision)]A;[Preview]5D;(command:fx-extension.localdebug)]A;Tip: Use [Run and Debug]5D;(command:workbench.view.debug) panel on the activity bar to browse all debug options in Teams.]]></Val>
          <Tgt Cat="Text" Stat="Loc" Orig="New">
            <Val><![CDATA[Per visualizzare l'anteprima dell'agente dichiarativo, [Provision]5D;(command:fx-extension.provision) per Microsoft 365 Copilot e avvia Microsoft 365 Copilot per [Preview]5D;(command:fx-extension.localdebug).]A;[Provision]5D;(command:fx-extension.provision)]A;[Preview]5D;(command:fx-extension.localdebug)]A;Suggerimento: usare il pannello [Run and Debug]5D;(command:workbench.view.debug) sulla barra attività per esplorare tutte le opzioni di debug in Teams.]]></Val>
          </Tgt>
        </Str>
        <Disp Icon="Str" />
      </Item>
