* text=auto
*.js eol=lf
*.cjs eol=lf
*.mjs eol=lf
*.json eol=lf
*.md eol=lf
*.ts eol=lf
*.tsx eol=lf
*.mts eol=lf
*.yml eol=lf
*.sh eol=lf
*.bicep eol=lf

# Localization files are maintained by the OneLocBuild pipeline as CRLF.
# Keep them as CRLF so contributor edits don't fight the pipeline (which
# would otherwise rewrite them on the next run).
packages/vscode-extension/package.nls.*.json eol=crlf
